{
  "name": "cterest",
  "version": "0.0.1",
  "private": true,
  "description": "Collect and organise private/shared/public media",
  "homepage": "https://github.com/clemeno/cterest#readme",
  "bugs": {
    "url": "https://github.com/clemeno/cterest/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://clemeno@github.com/clemeno/cterest.git"
  },
  "license": "MIT",
  "author": "CLEm",
  "type": "module",
  "main": "index.js",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun --filter './apps/*' dev",
    "web": "bun --filter web dev",
    "mock": "bun --filter mock-api dev",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "cme-utils": "~5.6.4",
    "eslint-utils": "~3.0.0"
  },
  "devDependencies": {
    "@types/bun": "~1.3.14",
    "eslint": "9.39.4",
    "neostandard": "~0.13.0"
  },
  "trustedDependencies": [
    "@parcel/watcher"
  ],
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "esbuild@0.28.1": true,
    "lmdb@3.4.2": true,
    "msgpackr-extract@3.0.4": true
  }
}
