/* cterest sample stylesheet */
:root {
	--brand: #1a2a30;
	--accent: #00ffdd;
}

.card {
	display: flex;
	gap: 1rem;
	padding: 16px 24px;
	background: var(--brand);
	color: #f8f8f2;
	border-radius: 8px;
}

.card:hover {
	outline: 2px solid var(--accent);
}

@media (max-width: 600px) {
	.card {
		flex-direction: column;
	}
}
