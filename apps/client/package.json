{
  "name": "client",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "lint": "eslint --fix",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~22.0.6",
    "@angular/cdk": "~22.0.4",
    "@angular/common": "~22.0.6",
    "@angular/compiler": "~22.0.6",
    "@angular/core": "~22.0.6",
    "@angular/forms": "~22.0.6",
    "@angular/material": "~22.0.4",
    "@angular/platform-browser": "~22.0.6",
    "@angular/router": "~22.0.6",
    "@fontsource/fira-code": "~5.2.7",
    "@shikijs/monaco": "~4.3.1",
    "cme-utils": "~6.0.0",
    "marked": "~18.0.6",
    "monaco-editor": "~0.55.1",
    "rxjs": "~7.8.2",
    "shiki": "~4.3.1",
    "tslib": "~2.8.1"
  },
  "devDependencies": {
    "@angular/build": "~22.0.6",
    "@angular/cli": "~22.0.6",
    "@angular/compiler-cli": "~22.0.6",
    "@types/bun": "~1.3.14",
    "@types/node": "~26.1.1",
    "eslint": "9.39.4",
    "istanbul-lib-instrument": "~6.0.3",
    "jsdom": "~29.1.1",
    "neostandard": "~0.13.0",
    "typescript": "6.0.3",
    "vitest": "~4.1.10"
  },
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "esbuild@0.28.1": true,
    "esbuild@0.27.7": true,
    "lmdb@3.5.4": true,
    "msgpackr-extract@3.0.4": true
  }
}
