{
  "name": "client",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~22.0.5",
    "@angular/cdk": "~22.0.3",
    "@angular/common": "~22.0.5",
    "@angular/compiler": "~22.0.5",
    "@angular/core": "~22.0.5",
    "@angular/forms": "~22.0.5",
    "@angular/material": "~22.0.3",
    "@angular/platform-browser": "~22.0.5",
    "@angular/router": "~22.0.5",
    "cme-utils": "~5.6.4",
    "eslint-utils": "~3.0.0",
    "rxjs": "~7.8.2",
    "tslib": "~2.8.1"
  },
  "devDependencies": {
    "@angular/build": "~22.0.5",
    "@angular/cli": "~22.0.5",
    "@angular/compiler-cli": "~22.0.5",
    "@types/bun": "~1.3.14",
    "eslint": "9.39.4",
    "istanbul-lib-instrument": "~6.0.3",
    "jsdom": "~29.1.1",
    "neostandard": "~0.13.0",
    "typescript": "~6.0.3",
    "vitest": "~4.1.10"
  }
}
